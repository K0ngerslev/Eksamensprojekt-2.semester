@page "/TeamChat"
@inject NavigationManager Navigation
@inject WebApp.Service.LoginService LoginService
@inject WebApp.Service.TeamchatAPIService TeamchatApiService
@using WebApp.Service
@implements IDisposable
@using Core.Model

<PageTitle>Team Chat</PageTitle>

<h3 class="mb-3">TeamChat</h3>

<div class="chat-container">
    @foreach (var msg in messages.OrderBy(m => m.Time))
    {
        <div class="message @(msg.User == LoginService?.CurrentUser?.Name ? "message-mine" : "message-other")">
            <div class="message-header">
                <strong>@msg.User</strong>
                <small>@msg.Time.ToString("HH:mm")</small>
            </div>
            <div class="message-text">@msg.Text</div>
        </div>
    }

    @if (messages.Count == 0)
    {
        <p class="text-center text-muted mt-5">Ingen beskeder endnu.</p>
    }
</div>

<div class="input-area">
    <div class="input-group">
        <textarea @bind="newMessage"
                  @onkeydown="HandleEnter"
                  class="message-input form-control"
                  rows="2"
                  placeholder="Skriv en besked her..."></textarea>
        <button class="send-btn btn btn-primary" @onclick="SendMessage">Send</button>
    </div>
</div>

@code {
    private List<TeamChatModel> messages = new();
    private string newMessage = "";
    private System.Timers.Timer? timer;

    protected override async Task OnInitializedAsync()
    {
        if (LoginService?.CurrentUser == null)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadMessages();

        timer = new System.Timers.Timer(2000);
        timer.Elapsed += async (s, e) => await LoadMessages();
        timer.Start();
    }

    private async Task LoadMessages()
    {
        messages = await TeamchatApiService.GetMessagesAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(newMessage) || LoginService?.CurrentUser == null)
            return;

        await TeamchatApiService.SendMessageAsync(LoginService.CurrentUser.Name, newMessage);
        newMessage = "";
        await LoadMessages();
    }

    private async Task HandleEnter(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendMessage();
        }
    }

    public void Dispose()
    {
        timer?.Stop();
        timer?.Dispose();
    }
}