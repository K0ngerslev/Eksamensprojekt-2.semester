@page "/TeamChat"
@inject NavigationManager Navigation
@inject WebApp.Service.LoginService LoginService
@inject HttpClient Http

<PageTitle>Team Chat</PageTitle>

<h3 class="mb-3">💬 Team Chat</h3>

<p><strong>Logged ind som: @LoginService?.CurrentUser?.Name</strong></p>

<!-- Chat vindue -->
<div class="chat-container">
    @foreach (var msg in messages.OrderBy(m => m.Time))
    {
        <div class="message @(msg.User == LoginService?.CurrentUser?.Name ? "message-mine" : "message-other")">
            <div class="message-header">
                <strong>@msg.User</strong>
                <small>@msg.Time.ToString("HH:mm")</small>
            </div>
            <div class="message-text">@msg.Text</div>
        </div>
    }
    
    @if (messages.Count == 0)
    {
        <p class="text-center text-muted mt-5">Ingen beskeder endnu.!</p>
    }
</div>

<!-- Input felt -->
<div class="input-area">
    <div class="input-group">
        <input @bind="newMessage" 
               @onkeydown="HandleEnter"
               class="message-input form-control" 
               placeholder="Skriv en besked her..." />
        <button class="send-btn btn btn-primary" @onclick="SendMessage">Send</button>
    </div>
</div>

@code {
    private List<ChatMessage> messages = new();
    private string newMessage = "";
    private System.Timers.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        if (LoginService?.CurrentUser == null)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadMessages();

        _timer = new System.Timers.Timer(2000);
        _timer.Elapsed += async (s, e) => await LoadMessages();
        _timer.Start();
    }

    private async Task LoadMessages()
    {
        try
        {
            var result = await Http.GetFromJsonAsync<List<ChatMessage>>("api/chat");
            if (result != null)
            {
                messages = result;
                StateHasChanged();
            }
        }
        catch { }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(newMessage) || LoginService?.CurrentUser == null)
            return;

        var dto = new SendChatMessageDto 
        { 
            User = LoginService.CurrentUser.Name, 
            Text = newMessage 
        };

        await Http.PostAsJsonAsync("api/chat", dto);
        newMessage = "";
        await LoadMessages();
    }

    private async Task HandleEnter(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SendMessage();
    }

    public void Dispose()
    {
        _timer?.Stop();
        _timer?.Dispose();
    }

    public class ChatMessage
    {
        public string User { get; set; } = "";
        public string Text { get; set; } = "";
        public DateTime Time { get; set; }
    }

    public class SendChatMessageDto
    {
        public string User { get; set; } = "";
        public string Text { get; set; } = "";
    }
}