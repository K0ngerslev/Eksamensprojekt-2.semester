@page "/Kalender"
@using System.Net.Http.Json
@using System.Text.Json
@using Core.Model
@inject WebApp.Service.AktivitetApiService aktivitetApiService
@inject WebApp.Service.ParticipationApiService participationApiService
@inject WebApp.Service.LoginService LoginService 


<PageTitle>Kalender</PageTitle>

<div class="activity-page">
    <div class="activity-page__header">
        <div>
            <h1>Aktiviteter</h1>
            <p>Her kan du se og oprette holdets aktiviteter.</p>
        </div>

        @if (LoginService.CurrentUser?.Role == "træner")
        {
            <button type="button" class="activity-page__add-button" @onclick="OpenAddDialog">
                Tilføj aktivitet
            </button>
        }
    </div>

    @if (aktiviteter.Count == 0 & LoginService.CurrentUser?.Role == "træner")
    {
        <div class="activity-page__empty-state">
            Ingen aktiviteter endnu. Tryk på <strong>Tilføj aktivitet</strong> for at oprette den første.
        </div>
    }
    else
    {
        <div class="activity-page__list">
            @foreach (var aktivitet in aktiviteter.OrderBy(a => a.Date).ThenBy(a => a.Time))
            {
                <article class="activity-card">
                    <div class="activity-card__top">
                        <h3>@aktivitet.ActivityType</h3>
                        <span>@FormatDate(aktivitet.Date) kl. @FormatTime(aktivitet.Time)</span>
                    </div>

                    <div class="activity-card__details">
                        <p><strong>Sted:</strong> @aktivitet.FieldOrLocation</p>

                        @if (!string.IsNullOrWhiteSpace(aktivitet.ChangingRoom))
                        {
                            <p><strong>Omklædning:</strong> @aktivitet.ChangingRoom</p>
                        }

                        @if (!string.IsNullOrWhiteSpace(aktivitet.AdditionalNotes))
                        {
                            <p><strong>Noter:</strong> @aktivitet.AdditionalNotes</p>
                        }
                    </div>
                    <div class="activity-card__actions">
                        @if (LoginService.CurrentUser?.Role == "træner")
                        {
                            <button type="button" class="activity-card__button" @onclick="() => OpenEditDialog(aktivitet)">Rediger</button>
                            <button type="button" class="activity-card__button activity-card__button--danger" @onclick="() => DeleteAktivitetAsync(aktivitet)">Slet</button>
                        }
                        @if (LoginService.CurrentUser?.Role == "træner")
                        {
                            <button type="button" class="activity-card__button"
                                    @onclick="() => ToggleParticipations(aktivitet.Id!)">
                                @(_expandedActivities.Contains(aktivitet.Id!) ? "Skjul deltagere" : "Vis deltagere")
                            </button>
                        }

                        @if (aktivitet.Id is not null && _expandedActivities.Contains(aktivitet.Id))
                        {
                            var list = _participations.GetValueOrDefault(aktivitet.Id) ?? [];
                            var attending = list.Where(p => p.IsAttending).ToList();
                            var notAttending = list.Where(p => !p.IsAttending).ToList();

                            <div class="participation-list">
                                <p><strong> Deltager (@attending.Count):</strong></p>
                                @if (attending.Count == 0)
                                {
                                    <span class="participation-none">Ingen endnu</span>
                                }
                                else
                                {
                                    @foreach (var p in attending)
                                    {
                                        <span class="participation-pill participation-pill--yes">@p.UserName</span>
                                    }
                                }

                                <p style="margin-top: 0.5rem"><strong> Deltager ikke (@notAttending.Count):</strong></p>
                                @if (notAttending.Count == 0)
                                {
                                    <span class="participation-none">Ingen endnu</span>
                                }
                                else
                                {
                                    @foreach (var p in notAttending)
                                    {
                                        <span class="participation-pill participation-pill--no">@p.UserName</span>
                                    }
                                }
                            </div>
                        }

                        @if (aktivitet.Id is not null & LoginService.CurrentUser?.Role == "Spiller")
                        {
                            var answer = myAnswers.GetValueOrDefault(aktivitet.Id);
                            <button type="button"
                                    class="activity-card__button @(answer == true ? "attend--yes" : "")"
                                    @onclick="() => SetAttending(aktivitet.Id!, true)">
                                Deltager
                            </button>
                            <button type="button"
                                    class="activity-card__button @(answer == false ? "attend--no" : "")"
                                    @onclick="() => SetAttending(aktivitet.Id!, false)">
                                Deltager ikke
                            </button>
                        }
                    </div>
                </article>
            }
        </div>
    }
</div>

@if (isDialogOpen)
{
    <div class="activity-modal-backdrop" @onclick="CloseAddDialog">
        <div class="activity-modal" @onclick:stopPropagation="true">
            <div class="activity-modal__header">
                <h2>@DialogTitle</h2>
                <button type="button" class="activity-modal__close" @onclick="CloseAddDialog">×</button>
            </div>

            @if (validationErrors.Count > 0)
            {
                <div class="activity-modal__errors">
                    @foreach (var error in validationErrors)
                    {
                        <p>@error</p>
                    }
                </div>
            }

            <EditForm Model="draftAktivitet" OnSubmit="HandleSubmitAsync">
                <div class="activity-modal__body">
                    <div class="activity-form__group">
                        <label for="activity-type">Aktivitetstype</label>
                        <InputText id="activity-type" class="form-control" @bind-Value="draftAktivitet.ActivityType" />
                    </div>

                    <div class="activity-form__row">
                        <div class="activity-form__group">
                            <label for="activity-date">Dato</label>
                            <input id="activity-date" class="form-control" type="date" value="@draftDate" @onchange="HandleDateChanged" />
                        </div>

                        <div class="activity-form__group">
                            <label for="activity-time">Tid</label>
                            <input id="activity-time" class="form-control" type="time" value="@draftTime" @onchange="HandleTimeChanged" />
                        </div>
                    </div>

                    <div class="activity-form__group">
                        <label for="activity-location">Bane / sted</label>
                        <InputText id="activity-location" class="form-control" @bind-Value="draftAktivitet.FieldOrLocation" />
                    </div>

                    <div class="activity-form__group">
                        <label for="activity-changing-room">Omklædningsrum</label>
                        <InputText id="activity-changing-room" class="form-control" @bind-Value="draftAktivitet.ChangingRoom" />
                    </div>

                    <div class="activity-form__group">
                        <label for="activity-notes">Yderligere noter</label>
                        <InputTextArea id="activity-notes" class="form-control" @bind-Value="draftAktivitet.AdditionalNotes" />
                    </div>
                </div>

                <div class="activity-modal__actions">
                    <button type="button" class="activity-modal__secondary-button" @onclick="CloseAddDialog">Annuller</button>
                    <button type="submit" class="activity-modal__primary-button">@SubmitButtonText</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private readonly List<Aktivitet> aktiviteter = new();
    private readonly List<string> validationErrors = new();
    // aktivitets-id -> denne brugers svar; null betyder endnu intet svar
    private readonly Dictionary<string, bool?> myAnswers = new();
    private readonly Dictionary<string, List<Participation>> _participations = new();
    private readonly HashSet<string> _expandedActivities = new();
    
    
    private Aktivitet draftAktivitet = new();
    private bool isDialogOpen;
    private bool isEditing;
    private string? editingAktivitetId;
    private string? draftDate;
    private string? draftTime;

    
    //loader aktiviteter fra API og viser dem på siden.
    protected override async Task OnInitializedAsync()
    {
        ResetDraft();
        var loaded = await aktivitetApiService.GetAllAsync();
        aktiviteter.AddRange(loaded);

        // Indlæser den aktuelle brugers svar for alle aktiviteter
        var userName = LoginService.CurrentUser?.Name;
        if (userName is not null)
        {
            // Henter deltagelseslisten for hver aktivitet og gemmer kun den aktuelle brugers svar.
            foreach (var a in aktiviteter.Where(a => a.Id is not null))
            {
                var participations = await participationApiService.GetByAktivitetIdAsync(a.Id!);
                var mine = participations.FirstOrDefault(p => p.UserName == userName);
                myAnswers[a.Id!] = mine?.IsAttending;
            }
        }
    }


    private void OpenAddDialog()
    {
        ResetDraft();
        isEditing = false;
        isDialogOpen = true;
    }

    private void OpenEditDialog(Aktivitet aktivitet)
    {
        validationErrors.Clear();
        isEditing = true;
        editingAktivitetId = aktivitet.Id;
        draftAktivitet = new Aktivitet
        {
            Id = aktivitet.Id,
            ActivityType = aktivitet.ActivityType,
            Date = aktivitet.Date,
            Time = aktivitet.Time,
            FieldOrLocation = aktivitet.FieldOrLocation,
            ChangingRoom = aktivitet.ChangingRoom,
            AdditionalNotes = aktivitet.AdditionalNotes
        };
        draftDate = aktivitet.Date?.ToString("yyyy-MM-dd");
        draftTime = aktivitet.Time?.ToString("HH:mm");
        isDialogOpen = true;
    }

    private void CloseAddDialog()
    {
        isDialogOpen = false;
        validationErrors.Clear();
    }

    private void HandleDateChanged(ChangeEventArgs args)
    {
        draftDate = args.Value?.ToString();
    }

    private void HandleTimeChanged(ChangeEventArgs args)
    {
        draftTime = args.Value?.ToString();
    }

    private async Task HandleSubmitAsync(EditContext _)
    {
        validationErrors.Clear();

        // Browseren giver dato/tid som tekst, så de skal parses før gemning.
        if (!DateOnly.TryParse(draftDate, out var parsedDate))
        {
            validationErrors.Add("Du skal vælge en gyldig dato.");
        }

        if (!TimeOnly.TryParse(draftTime, out var parsedTime))
        {
            validationErrors.Add("Du skal vælge et gyldigt tidspunkt.");
        }

        if (validationErrors.Count > 0)
        {
            return;
        }

        draftAktivitet.Date = parsedDate;
        draftAktivitet.Time = parsedTime;
        NormalizeDraft();

        // Bygger et rent objekt til API'et i stedet for at sende UI-kladdeobjektet direkte.
        var ak = new Aktivitet
        {
            Id = editingAktivitetId,
            ActivityType = draftAktivitet.ActivityType,
            Date = draftAktivitet.Date,
            Time = draftAktivitet.Time,
            FieldOrLocation = draftAktivitet.FieldOrLocation,
            ChangingRoom = draftAktivitet.ChangingRoom,
            AdditionalNotes = draftAktivitet.AdditionalNotes
        };
        var response = isEditing && !string.IsNullOrWhiteSpace(editingAktivitetId)
            ? await aktivitetApiService.UpdateAsync(editingAktivitetId, ak)
            : await aktivitetApiService.AddAsync(ak);

        if (!response.IsSuccessStatusCode)
        {
            validationErrors.AddRange(await ReadErrorsAsync(response));
            return;
        }

        if (isEditing)
        {
            // Opdaterer den lokale liste, så UI'et ændrer sig med det samme efter en succesfuld gemning.
            var existingAktivitet = aktiviteter.FirstOrDefault(a => a.Id == editingAktivitetId);
            if (existingAktivitet is not null)
            {
                existingAktivitet.ActivityType = ak.ActivityType;
                existingAktivitet.Date = ak.Date;
                existingAktivitet.Time = ak.Time;
                existingAktivitet.FieldOrLocation = ak.FieldOrLocation;
                existingAktivitet.ChangingRoom = ak.ChangingRoom;
                existingAktivitet.AdditionalNotes = ak.AdditionalNotes;
            }
        }
        else
        {
            // Nye aktiviteter kan komme retur med et genereret id fra API'et.
            var savedAktivitet = await response.Content.ReadFromJsonAsync<Aktivitet>();
            aktiviteter.Add(savedAktivitet ?? ak);
        }

        CloseAddDialog();
        ResetDraft();
    }

    private void ResetDraft()
    {
        draftAktivitet = new Aktivitet();
        editingAktivitetId = null;
        isEditing = false;
        draftDate = DateTime.Today.ToString("yyyy-MM-dd");
        draftTime = DateTime.Now.ToString("HH:mm");
        validationErrors.Clear();
    }

    private void NormalizeDraft()
    {
        draftAktivitet.ActivityType = draftAktivitet.ActivityType?.Trim();
        draftAktivitet.FieldOrLocation = draftAktivitet.FieldOrLocation?.Trim();
        draftAktivitet.ChangingRoom = string.IsNullOrWhiteSpace(draftAktivitet.ChangingRoom)
            ? null
            : draftAktivitet.ChangingRoom.Trim();
        draftAktivitet.AdditionalNotes = string.IsNullOrWhiteSpace(draftAktivitet.AdditionalNotes)
            ? null
            : draftAktivitet.AdditionalNotes.Trim();
    }

    private async Task DeleteAktivitetAsync(Aktivitet aktivitet)
    {
        if (string.IsNullOrWhiteSpace(aktivitet.Id))
        {
            validationErrors.Clear();
            validationErrors.Add("Aktiviteten kan ikke slettes uden et id.");
            return;
        }

        var response = await aktivitetApiService.DeleteAsync(aktivitet.Id);
        if (!response.IsSuccessStatusCode)
        {
            validationErrors.Clear();
            validationErrors.AddRange(await ReadErrorsAsync(response));
            return;
        }

        aktiviteter.Remove(aktivitet);
    }

    private static async Task<List<string>> ReadErrorsAsync(HttpResponseMessage response)
    {
        var content = await response.Content.ReadAsStringAsync();
        if (string.IsNullOrWhiteSpace(content))
        {
            return ["Noget gik galt."];
        }

        try
        {
            using var document = JsonDocument.Parse(content);
            var root = document.RootElement;
            var errors = new List<string>();

            if (root.TryGetProperty("errors", out var errorGroups) && errorGroups.ValueKind == JsonValueKind.Object)
            {
                foreach (var errorGroup in errorGroups.EnumerateObject())
                {
                    if (errorGroup.Value.ValueKind != JsonValueKind.Array)
                    {
                        continue;
                    }

                    foreach (var error in errorGroup.Value.EnumerateArray())
                    {
                        var message = error.GetString();
                        if (!string.IsNullOrWhiteSpace(message))
                        {
                            errors.Add(message);
                        }
                    }
                }
            }

            if (errors.Count > 0)
            {
                return errors.Distinct().ToList();
            }

            if (root.TryGetProperty("detail", out var detail) && !string.IsNullOrWhiteSpace(detail.GetString()))
            {
                return [detail.GetString()!];
            }

            if (root.TryGetProperty("title", out var title) && !string.IsNullOrWhiteSpace(title.GetString()))
            {
                return [title.GetString()!];
            }
        }
        catch (JsonException)
        {
        }

        return [content];
    }

    private string DialogTitle => isEditing ? "Rediger aktivitet" : "Tilføj aktivitet";

    private string SubmitButtonText => isEditing ? "Gem ændringer" : "Gem aktivitet";

    private static string FormatDate(DateOnly? date)
    {
        return date?.ToString("dd/MM/yyyy") ?? "-";
    }

    private static string FormatTime(TimeOnly? time)
    {
        return time?.ToString("HH:mm") ?? "-";
    }
    private async Task SetAttending(string aktivitetId, bool attending)
    {
        var userName = LoginService.CurrentUser?.Name ?? "Ukendt";
        await participationApiService.UpsertAsync(new Participation
        {
            AktivitetId = aktivitetId,
            UserName = userName,
            IsAttending = attending
        });
        // Gemmer det valgte svar lokalt, så knaptilstanden opdateres uden genindlæsning.
        myAnswers[aktivitetId] = attending;
    }

    private async Task ToggleParticipations(string aktivitetId)
    {
        if (_expandedActivities.Contains(aktivitetId))
        {
            _expandedActivities.Remove(aktivitetId);
            return;
        }
        _expandedActivities.Add(aktivitetId);

        if (!_participations.ContainsKey(aktivitetId))
        {
            var list = await participationApiService.GetByAktivitetIdAsync(aktivitetId);
            _participations[aktivitetId] = list;
        }
    }
    
    }
}

